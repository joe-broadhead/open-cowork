{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/joe-broadhead/open-wiki/v0.0.0/schemas/openwiki/v0/proposal-comment.schema.json",
  "title": "OpenWiki Proposal Comment Record",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "uri", "type", "proposal_id", "actor_id", "body", "created_at", "path"],
  "properties": {
    "id": { "type": "string", "pattern": "^comment:" },
    "uri": { "type": "string", "pattern": "^openwiki://comment/" },
    "type": { "const": "comment" },
    "proposal_id": { "type": "string", "pattern": "^proposal:" },
    "actor_id": { "type": "string", "pattern": "^actor:" },
    "body": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "path": { "type": "string" }
  }
}
