{
  "annotations": {
    "list": []
  },
  "editable": true,
  "panels": [
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "targets": [
        {
          "expr": "openwiki_ready",
          "legendFormat": "ready"
        }
      ],
      "title": "Readiness",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "gridPos": {
        "h": 6,
        "w": 9,
        "x": 6,
        "y": 0
      },
      "id": 2,
      "targets": [
        {
          "expr": "sum(rate(openwiki_http_requests_total[5m])) by (route, status)",
          "legendFormat": "{{route}} {{status}}"
        }
      ],
      "title": "HTTP Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "gridPos": {
        "h": 6,
        "w": 9,
        "x": 15,
        "y": 0
      },
      "id": 3,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(openwiki_http_request_duration_seconds_bucket[5m])) by (le, route))",
          "legendFormat": "p95 {{route}}"
        }
      ],
      "title": "HTTP Latency P95",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "id": 4,
      "targets": [
        {
          "expr": "sum(openwiki_queue_jobs) by (status)",
          "legendFormat": "{{status}}"
        }
      ],
      "title": "Queue Jobs",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "id": 5,
      "targets": [
        {
          "expr": "sum(rate(openwiki_mcp_tool_calls_total[5m])) by (tool, status)",
          "legendFormat": "{{tool}} {{status}}"
        }
      ],
      "title": "MCP Tool Calls",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 13
      },
      "id": 6,
      "targets": [
        {
          "expr": "sum(rate(openwiki_source_fetch_attempts_total[15m])) by (connector_kind, status)",
          "legendFormat": "{{connector_kind}} {{status}}"
        }
      ],
      "title": "Source Fetch Attempts",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 13
      },
      "id": 7,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(openwiki_search_duration_seconds_bucket[5m])) by (le, backend))",
          "legendFormat": "p95 {{backend}}"
        }
      ],
      "title": "Search Latency",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "id": 8,
      "targets": [
        {
          "expr": "increase(openwiki_write_lock_acquisitions_total[10m])",
          "legendFormat": "{{operation}} {{status}}"
        }
      ],
      "title": "Write Lock Activity",
      "type": "timeseries"
    }
  ],
