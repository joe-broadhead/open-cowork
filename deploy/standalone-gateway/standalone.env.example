# Open Cowork Standalone Gateway.
# Copy to a private file and chmod 0600. Do not commit real values.

OPEN_COWORK_STANDALONE_GATEWAY_DATABASE_URL=postgres://open_cowork:replace-with-password@127.0.0.1:5432/open_cowork_gateway
OPEN_COWORK_STANDALONE_GATEWAY_DATABASE_SSL=false
OPEN_COWORK_STANDALONE_GATEWAY_ADMIN_TOKEN=replace-with-random-admin-token

OPEN_COWORK_STANDALONE_GATEWAY_OPENCODE_URL=http://127.0.0.1:4096
OPEN_COWORK_STANDALONE_GATEWAY_ALLOW_PRIVATE_DNS=false
OPEN_COWORK_STANDALONE_GATEWAY_RUNTIME_ROOT=/var/lib/open-cowork/standalone-gateway

OPEN_COWORK_STANDALONE_GATEWAY_HOST=127.0.0.1
OPEN_COWORK_STANDALONE_GATEWAY_PORT=8795
OPEN_COWORK_STANDALONE_GATEWAY_PUBLIC_URL=
OPEN_COWORK_STANDALONE_GATEWAY_DEPLOYMENT_MODE=solo

OPEN_COWORK_STANDALONE_GATEWAY_RETENTION_SESSION_DAYS=90
OPEN_COWORK_STANDALONE_GATEWAY_RETENTION_ARTIFACT_DAYS=30
OPEN_COWORK_STANDALONE_GATEWAY_RETENTION_AUDIT_DAYS=365

OPEN_COWORK_STANDALONE_GATEWAY_TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token
OPEN_COWORK_STANDALONE_GATEWAY_TELEGRAM_PROVIDER_ID=telegram
OPEN_COWORK_STANDALONE_GATEWAY_TELEGRAM_CHANNEL_BINDING_ID=telegram
OPEN_COWORK_STANDALONE_GATEWAY_TELEGRAM_MODE=polling
OPEN_COWORK_STANDALONE_GATEWAY_TELEGRAM_PUBLIC_URL=
OPEN_COWORK_STANDALONE_GATEWAY_TELEGRAM_WEBHOOK_SECRET=

OPEN_COWORK_STANDALONE_GATEWAY_WEBHOOK_PROVIDER_ID=webhook
OPEN_COWORK_STANDALONE_GATEWAY_WEBHOOK_CHANNEL_BINDING_ID=webhook
OPEN_COWORK_STANDALONE_GATEWAY_WEBHOOK_SHARED_SECRET=
OPEN_COWORK_STANDALONE_GATEWAY_WEBHOOK_DELIVERY_URL=
