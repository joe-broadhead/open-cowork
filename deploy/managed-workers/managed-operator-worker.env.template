# Managed-operator worker template.
# Keep this file generic. Real project ids, account ids, domains, credentials,
# prices, customers, and launch evidence belong in a private operations repo.

OPEN_COWORK_CLOUD_ROLE=worker
OPEN_COWORK_CLOUD_PROFILE=full
OPEN_COWORK_CLOUD_ROOT=/data/open-cowork-cloud
OPEN_COWORK_CLOUD_WORKER_ID=worker-REGION-POOL-ORDINAL
OPEN_COWORK_CLOUD_WORKER_POLL_MS=1000
OPEN_COWORK_CLOUD_SHUTDOWN_GRACE_MS=300000

# Use provider-native secret refs where supported by the deployment platform.
OPEN_COWORK_CLOUD_CONTROL_PLANE_URL=postgres://USER:PASSWORD@DATABASE_HOST:5432/open_cowork
OPEN_COWORK_CLOUD_SECRET_KEY_REF=gcp-sm://projects/PROJECT/secrets/open-cowork-cloud-secret-key/versions/latest
OPEN_COWORK_CLOUD_INTERNAL_TOKEN_REF=gcp-sm://projects/PROJECT/secrets/open-cowork-internal-token/versions/latest
OPEN_COWORK_CLOUD_COOKIE_SECRET_REF=gcp-sm://projects/PROJECT/secrets/open-cowork-cookie-secret/versions/latest

OPEN_COWORK_CLOUD_CHECKPOINTS_ENABLED=true
OPEN_COWORK_CLOUD_OBJECT_STORE_KIND=gcs
OPEN_COWORK_CLOUD_OBJECT_STORE_BUCKET=OPEN_COWORK_BUCKET
OPEN_COWORK_CLOUD_OBJECT_STORE_REGION=REGION
OPEN_COWORK_CLOUD_OBJECT_STORE_PREFIX=workers/managed/

OPEN_COWORK_CLOUD_SERVICE_NAME=open-cowork-cloud-worker
OPEN_COWORK_CLOUD_SERVICE_VERSION=vX.Y.Z
OPEN_COWORK_CLOUD_LOG_FORMAT=json
OPEN_COWORK_CLOUD_OTLP_ENDPOINT=https://otel.example.com/v1/traces
OPEN_COWORK_CLOUD_OTLP_HEADERS=REPLACE_WITH_PLATFORM_SECRET

# Hosted operators should keep these enabled and tune plan-specific limits in
# downstream config or entitlement policy.
OPEN_COWORK_CLOUD_ABUSE_ENABLED=true
OPEN_COWORK_CLOUD_MAX_CONCURRENT_SESSIONS_PER_ORG=50
OPEN_COWORK_CLOUD_MAX_CONCURRENT_WORKFLOW_RUNS_PER_ORG=20
OPEN_COWORK_CLOUD_MAX_ACTIVE_WORKERS_PER_ORG=8
OPEN_COWORK_CLOUD_MAX_QUEUED_COMMANDS_PER_ORG=250
OPEN_COWORK_CLOUD_MAX_QUEUE_AGE_MS=900000
OPEN_COWORK_CLOUD_MAX_PROMPTS_PER_HOUR=500
OPEN_COWORK_CLOUD_MAX_WORKFLOW_RUNS_PER_HOUR=100
OPEN_COWORK_CLOUD_MAX_GATEWAY_PROMPTS_PER_HOUR=250
OPEN_COWORK_CLOUD_MAX_WORKER_MINUTES_PER_HOUR=1000
