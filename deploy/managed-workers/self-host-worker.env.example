# Self-hosted internal worker pool example.
# Local/demo placeholders only. Replace in a private deployment repo or secret
# store before exposing the worker to real users.

OPEN_COWORK_CLOUD_ROLE=worker
OPEN_COWORK_CLOUD_PROFILE=full
OPEN_COWORK_CLOUD_ROOT=/data/open-cowork-cloud
OPEN_COWORK_CLOUD_WORKER_ID=worker-REGION-POOL-001
OPEN_COWORK_CLOUD_WORKER_POLL_MS=1000
OPEN_COWORK_CLOUD_SHUTDOWN_GRACE_MS=300000

# Shared control plane and secrets.
OPEN_COWORK_CLOUD_CONTROL_PLANE_URL=postgres://USER:PASSWORD@postgres.example.internal:5432/open_cowork
OPEN_COWORK_CLOUD_SECRET_KEY_REF=env:OPEN_COWORK_CLOUD_SECRET_KEY
OPEN_COWORK_CLOUD_INTERNAL_TOKEN_REF=env:OPEN_COWORK_CLOUD_INTERNAL_TOKEN

# Checkpoints/artifacts must use shared object storage when more than one
# worker can process the same org or profile.
OPEN_COWORK_CLOUD_CHECKPOINTS_ENABLED=true
OPEN_COWORK_CLOUD_OBJECT_STORE_KIND=s3
OPEN_COWORK_CLOUD_OBJECT_STORE_BUCKET=OPEN_COWORK_BUCKET
OPEN_COWORK_CLOUD_OBJECT_STORE_REGION=REGION
OPEN_COWORK_CLOUD_OBJECT_STORE_PREFIX=workers/self-hosted/
OPEN_COWORK_CLOUD_OBJECT_STORE_ENDPOINT=
OPEN_COWORK_CLOUD_OBJECT_STORE_ACCESS_KEY_ID=REPLACE_FROM_SECRET_MANAGER
OPEN_COWORK_CLOUD_OBJECT_STORE_SECRET_ACCESS_KEY=REPLACE_FROM_SECRET_MANAGER

# Observability.
OPEN_COWORK_CLOUD_SERVICE_NAME=open-cowork-cloud-worker
OPEN_COWORK_CLOUD_SERVICE_VERSION=vX.Y.Z
OPEN_COWORK_CLOUD_LOG_FORMAT=json
OPEN_COWORK_CLOUD_OTLP_ENDPOINT=https://otel-collector.example.internal/v1/traces
OPEN_COWORK_CLOUD_OTLP_HEADERS_REF=env:OPEN_COWORK_CLOUD_OTLP_HEADERS

# Self-hosters can run without commercial billing, while still keeping abuse
# and runaway-cost limits enabled.
OPEN_COWORK_CLOUD_ABUSE_ENABLED=true
OPEN_COWORK_CLOUD_MAX_ACTIVE_WORKERS_PER_ORG=4
OPEN_COWORK_CLOUD_MAX_QUEUED_COMMANDS_PER_ORG=100
OPEN_COWORK_CLOUD_MAX_QUEUE_AGE_MS=600000
OPEN_COWORK_CLOUD_MAX_WORKER_MINUTES_PER_HOUR=240
