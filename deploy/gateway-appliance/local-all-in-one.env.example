# Local all-in-one Cloud + Cloud Channel Gateway appliance.
# Copy to a private file such as .env.gateway and chmod 0600.

OPEN_COWORK_CLOUD_PUBLIC_URL=http://localhost:8787
OPEN_COWORK_CLOUD_SECRET_KEY=replace-with-random-local-secret-key
OPEN_COWORK_CLOUD_COOKIE_SECRET=replace-with-random-local-cookie-secret
OPEN_COWORK_CLOUD_INTERNAL_TOKEN=replace-with-random-local-internal-token
OPEN_COWORK_CLOUD_OBJECT_STORE_SECRET_ACCESS_KEY=replace-with-random-minio-secret

OPEN_COWORK_CLOUD_BASE_URL=http://open-cowork-cloud:8787
OPEN_COWORK_GATEWAY_ALLOW_INSECURE_HTTP=true
OPEN_COWORK_GATEWAY_SERVICE_TOKEN=replace-with-local-cloud-gateway-token
OPEN_COWORK_GATEWAY_ADMIN_TOKEN=replace-with-random-local-gateway-admin-token
OPEN_COWORK_GATEWAY_HOST=127.0.0.1
OPEN_COWORK_GATEWAY_PORT=8790
OPEN_COWORK_GATEWAY_PUBLIC_URL=
OPEN_COWORK_GATEWAY_PRODUCT_MODE=cloud_channel
OPEN_COWORK_GATEWAY_MODE=self-host
OPEN_COWORK_GATEWAY_METRICS_ENABLED=false
OPEN_COWORK_GATEWAY_DIAGNOSTICS_ENABLED=false
OPEN_COWORK_GATEWAY_ALLOW_LOOPBACK_OPERATOR_BYPASS=false
OPEN_COWORK_GATEWAY_MAX_REQUEST_BODY_BYTES=1048576
OPEN_COWORK_GATEWAY_TRUST_PROXY_HEADERS=false
OPEN_COWORK_GATEWAY_TRUSTED_PROXY_CIDRS=
OPEN_COWORK_GATEWAY_CLOUD_REQUEST_TIMEOUT_MS=30000
OPEN_COWORK_GATEWAY_WEBHOOK_DELIVERY_TIMEOUT_MS=15000
OPEN_COWORK_GATEWAY_SMTP_TIMEOUT_MS=30000
OPEN_COWORK_GATEWAY_SHUTDOWN_DRAIN_TIMEOUT_MS=10000

OPEN_COWORK_GATEWAY_TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token
OPEN_COWORK_GATEWAY_TELEGRAM_CHANNEL_BINDING_ID=telegram
OPEN_COWORK_GATEWAY_TELEGRAM_MODE=polling
OPEN_COWORK_GATEWAY_TELEGRAM_PUBLIC_URL=
OPEN_COWORK_GATEWAY_TELEGRAM_WEBHOOK_SECRET=
OPEN_COWORK_GATEWAY_EMAIL_MAX_ATTACHMENT_BYTES=1048576
OPEN_COWORK_GATEWAY_WEBHOOK_MAX_ATTACHMENT_BYTES=1048576

# Set true only for loopback smoke tests.
OPEN_COWORK_GATEWAY_ENABLE_FAKE_PROVIDER=false
OPEN_COWORK_GATEWAY_ALLOW_PUBLIC_FAKE_PROVIDER=false
