{
  "private": true,
  "name": "open-cowork",
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "description": "Desktop workspace for OpenCode sessions, agents, tools, skills, and workflows",
  "keywords": [
    "electron",
    "opencode",
    "ai-agents",
    "desktop-app",
    "mcp",
    "workflows",
    "typescript"
  ],
  "author": "Joe Broadhead",
  "license": "MIT",
  "homepage": "https://github.com/joe-broadhead/open-cowork",
  "repository": {
    "type": "git",
    "url": "https://github.com/joe-broadhead/open-cowork.git"
  },
  "bugs": {
    "url": "https://github.com/joe-broadhead/open-cowork/issues"
  },
  "scripts": {
    "dev": "pnpm build:packages && pnpm design-tokens:build && pnpm build:mcps && pnpm --filter @open-cowork/desktop dev",
    "build": "pnpm build:packages && pnpm design-tokens:build && pnpm build:mcps && pnpm build:gateway && pnpm build:standalone-gateway && pnpm --filter @open-cowork/desktop build",
    "build:desktop": "pnpm --filter @open-cowork/desktop build",
    "build:gateway": "pnpm --filter @open-cowork/gateway build",
    "build:standalone-gateway": "pnpm --filter @open-cowork/standalone-gateway build",
    "build:mcps": "pnpm --filter=./mcps/* build",
    "build:packages": "pnpm --workspace-concurrency=1 --filter=./packages/* build",
    "build:shared": "pnpm --filter @open-cowork/shared build",
    "design-tokens:build": "node --no-warnings --experimental-strip-types scripts/generate-design-token-css.ts",
    "design-tokens:check": "node --no-warnings --experimental-strip-types scripts/generate-design-token-css.ts --check",
    "docs:build": "node scripts/docs-build.mjs build",
    "docs:vendor:build": "node scripts/build-docs-mermaid-vendor.mjs",
    "docs:vendor:check": "node scripts/build-docs-mermaid-vendor.mjs --check",
    "docs:serve": "node scripts/docs-build.mjs serve",
    "typecheck": "pnpm build:packages && pnpm design-tokens:build && pnpm typecheck:cloud-server && pnpm typecheck:mcps && pnpm typecheck:gateway && pnpm typecheck:standalone-gateway && pnpm --filter @open-cowork/desktop build:electron && pnpm --filter @open-cowork/desktop typecheck",
    "typecheck:cloud-server": "pnpm --filter @open-cowork/cloud-server typecheck",
    "typecheck:gateway": "pnpm --filter @open-cowork/gateway typecheck",
    "typecheck:standalone-gateway": "pnpm --filter @open-cowork/standalone-gateway typecheck",
    "typecheck:mcps": "pnpm --filter=./mcps/* typecheck",
    "dist": "pnpm build && pnpm --filter @open-cowork/desktop dist",
    "lint": "eslint . --max-warnings 0 && pnpm design-tokens:check && node scripts/lint.mjs && node scripts/check-design-token-usage.mjs && node scripts/check-import-cycles.mjs && node scripts/build-docs-mermaid-vendor.mjs --check && node scripts/check-preload-channels.mjs && node scripts/check-shared-dist.mjs",
    "lint:dead-code": "knip --production --files --exports",
    "lint:a11y": "eslint --config eslint.a11y.config.mjs 'packages/app/src/**/*.tsx' 'packages/ui/src/**/*.tsx'",
    "audit:prod": "node scripts/pnpm-audit.mjs --prod --audit-level moderate",
    "audit:full": "node scripts/pnpm-audit.mjs --audit-level high",
    "check:bundle-size": "node scripts/check-bundle-size.mjs",
    "i18n:check": "node scripts/i18n-coverage.mjs",
    "test": "pnpm test:prepare && pnpm --workspace-concurrency=1 --filter=./packages/* test && pnpm --filter=./mcps/* test && pnpm --filter @open-cowork/gateway test && pnpm --filter @open-cowork/standalone-gateway test && node scripts/run-node-tests.mjs",
    "test:prepare": "pnpm build:shared && pnpm --filter @open-cowork/runtime-host build && pnpm design-tokens:build && node scripts/ensure-electron-binary.mjs",
    "test:cloud-continuation": "pnpm test:prepare && pnpm build:gateway && node scripts/run-node-tests.mjs tests/cloud-continuation-e2e.test.ts",
    "test:live-scenarios": "node scripts/live-scenario-evidence.mjs --suite deploy/scenarios/local-desktop-scenarios.json --output-dir .open-cowork-test/live-scenarios --execute",
    "test:renderer": "pnpm --filter @open-cowork/app test:renderer",
    "test:coverage": "pnpm test:coverage:node && pnpm test:coverage:renderer && node scripts/coverage-summary.mjs --check",
    "test:coverage:node": "pnpm test:prepare && pnpm --workspace-concurrency=1 --filter=./packages/* test && pnpm --filter=./mcps/* test && pnpm --filter @open-cowork/gateway test && pnpm --filter @open-cowork/standalone-gateway test && node scripts/run-node-tests.mjs --coverage && node scripts/run-workspace-node-tests.mjs --coverage && node scripts/coverage-summary.mjs --check --node-only --no-write",
    "test:coverage:renderer": "pnpm --filter @open-cowork/app test:coverage:renderer",
    "test:e2e": "pnpm --filter @open-cowork/desktop test:e2e",
    "test:e2e:packaged": "pnpm --filter @open-cowork/desktop test:e2e:packaged",
    "test:e2e:packaged:optional": "pnpm --filter @open-cowork/desktop test:e2e:packaged:optional",
    "test:windows-prepackage": "pnpm test:prepare && pnpm --filter @open-cowork/cloud-client build && node scripts/check-preload-channels.mjs && node scripts/run-node-tests.mjs tests/artifact-index.test.ts tests/session-artifact-access.test.ts tests/ipc-handler-registration.test.ts tests/desktop-after-pack.test.ts tests/update-service.test.ts tests/update-check-version.test.ts tests/update-release-source.test.ts tests/release-windows-signing-mode.test.ts tests/runtime-environment.test.ts tests/packaged-executable-preflight.test.ts tests/windows-signing-targets.test.ts",
    "test:e2e:evals": "pnpm --filter @open-cowork/desktop test:e2e:evals",
    "screenshots": "pnpm --filter @open-cowork/desktop screenshots",
    "cloud:dev": "node --no-warnings --experimental-strip-types scripts/open-cowork-cloud.ts",
    "cloud:build": "node scripts/build-cloud.mjs",
    "cloud:start": "node --experimental-sqlite apps/desktop/dist/cloud/open-cowork-cloud.mjs",
    "cloud:migrate": "node --no-warnings --experimental-strip-types scripts/open-cowork-cloud-migrate.ts",
    "cloud:migrate:start": "node --experimental-sqlite apps/desktop/dist/cloud/open-cowork-cloud-migrate.mjs",
    "cloud:smoke:import": "node scripts/cloud-bundle-import-smoke.mjs",
    "cloud:smoke": "pnpm cloud:build && pnpm cloud:smoke:import",
    "cloud:smoke:compose": "bash scripts/ci-cloud-compose-smoke.sh",
    "deploy:validate": "node scripts/validate-deployment-configs.mjs",
    "deploy:smoke": "node scripts/smoke-deployment.mjs",
    "deploy:smoke:strict": "node scripts/strict-deployment-smoke.mjs",
    "deploy:desktop:smoke": "pnpm build:shared && node --no-warnings --experimental-strip-types scripts/desktop-cloud-sync-smoke.mjs",
    "deploy:gateway:smoke": "pnpm build:gateway && node scripts/gateway-cloud-smoke.mjs",
    "deploy:standalone-gateway:smoke": "pnpm build:standalone-gateway && node apps/standalone-gateway/dist/main.js smoke",
    "deploy:standalone-gateway:validate": "node scripts/validate-standalone-gateway.mjs",
    "deploy:continuation:smoke": "pnpm build:gateway && pnpm build:shared && node --no-warnings --experimental-strip-types scripts/cloud-continuation-smoke.mjs",
    "gateway:setup": "node scripts/gateway-appliance-setup.mjs",
    "standalone-gateway:setup": "node scripts/standalone-gateway-setup.mjs",
    "headless:host": "node --no-warnings --experimental-strip-types scripts/headless-host.ts",
    "headless:check": "node --no-warnings --experimental-strip-types scripts/headless-host.ts check",
    "deploy:gcp:preflight": "node scripts/gcp-reference-preflight.mjs",
    "deploy:gcp:smoke": "node scripts/gcp-reference-smoke.mjs",
    "deploy:load:plan": "node scripts/launch-readiness.mjs --mode plan",
    "deploy:load": "node scripts/launch-readiness.mjs --mode load",
    "deploy:load:strict": "node scripts/launch-readiness.mjs --mode load --strict",
    "deploy:soak": "node scripts/launch-readiness.mjs --mode soak",
    "deploy:soak:strict": "node scripts/launch-readiness.mjs --mode soak --strict",
    "deploy:failover:drill": "node scripts/launch-failover-drill.mjs",
    "deploy:failover:drill:dry-run": "node scripts/launch-failover-drill.mjs --dry-run",
    "deploy:launch:validate": "node scripts/validate-launch-readiness.mjs",
    "deploy:launch:evidence:validate": "node scripts/validate-launch-evidence-manifest.mjs",
    "deploy:promotion:validate": "node scripts/validate-release-promotion.mjs",
    "deploy:private-beta:validate": "node scripts/validate-private-beta-package.mjs",
    "ops:validate": "node --no-warnings --experimental-strip-types scripts/check-opencode-compatibility.ts && node scripts/validate-ops-readiness.mjs && node scripts/validate-release-gates.mjs",
    "release:gates:validate": "node scripts/validate-release-gates.mjs",
    "notices": "node scripts/generate-third-party-notices.mjs",
    "license:check": "node scripts/check-license-compatibility.mjs",
    "proof:opencode:compatibility": "node --no-warnings --experimental-strip-types scripts/check-opencode-compatibility.ts",
    "proof:cloud:opencode-portability": "node --no-warnings --experimental-strip-types scripts/opencode-portability-proof.ts",
    "proof:sandbox:opencode-session": "node --no-warnings --experimental-strip-types scripts/sandbox-opencode-session-smoke.ts",
    "perf:bench": "node --no-warnings --experimental-sqlite --experimental-strip-types scripts/perf-benchmark.ts",
    "perf:baseline": "node --no-warnings --experimental-sqlite --experimental-strip-types scripts/perf-benchmark.ts --write",
    "perf:check": "node --no-warnings --experimental-sqlite --experimental-strip-types scripts/perf-benchmark.ts --check",
    "clean": "pnpm -r exec rm -rf dist"
  },
  "engines": {
    "node": ">=22.13",
    "pnpm": "10.32.1",
    "npm": "0"
  },
  "pnpm": {
    "auditConfig": {
      "ignoreCves": [],
      "ignoreGhsas": []
    }
  },
  "dependencies": {
    "@open-cowork/runtime-host": "workspace:*",
    "@open-cowork/shared": "workspace:*"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "pg": "^8.22.0",
    "@open-cowork/cloud-server": "workspace:*",
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-security": "^4.0.1",
    "globals": "^17.7.0",
    "knip": "^6.24.0",
    "zod": "^4.4.3"
  }
}
