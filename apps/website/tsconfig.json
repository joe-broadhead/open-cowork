{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noUncheckedIndexedAccess": true,
    "outDir": "dist",
    "rootDir": "src",
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM"],
    "types": ["node", "react", "react-dom"],
    "paths": {
      "@open-cowork/shared": ["../../packages/shared/dist/index.d.ts"],
      "@open-cowork/shared/*": ["../../packages/shared/dist/*"],
      "@open-cowork/ui": ["../../packages/ui/dist/index.d.ts"],
      "@open-cowork/ui/app-api": ["../../packages/ui/dist/AppApiProvider.d.ts"],
      "@open-cowork/ui/badge": ["../../packages/ui/dist/Badge.d.ts"],
      "@open-cowork/ui/card": ["../../packages/ui/dist/Card.d.ts"],
      "@open-cowork/ui/primitive-gallery": ["../../packages/ui/dist/PrimitiveGallery.d.ts"],
      "@open-cowork/ui/studio": ["../../packages/ui/dist/StudioPrimitives.d.ts"],
      "@open-cowork/ui/*": ["../../packages/ui/dist/*"]
    }
  },
  "include": ["src/**/*"]
}
