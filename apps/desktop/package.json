{
  "name": "@open-cowork/desktop",
  "productName": "Open Cowork",
  "version": "0.1.0",
  "private": true,
  "description": "Open Cowork desktop app powered by OpenCode",
  "author": "Joe Broadhead",
  "license": "MIT",
  "homepage": "https://github.com/joe-broadhead/open-cowork",
  "repository": {
    "type": "git",
    "url": "https://github.com/joe-broadhead/open-cowork.git"
  },
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:electron": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.preload.json --noEmit",
    "typecheck": "tsc --noEmit",
    "start": "electron .",
    "test:e2e": "pnpm --dir ../.. build:shared && pnpm build && pnpm build:electron && node --no-warnings --experimental-strip-types --test-reporter=spec --test 'tests/*.smoke.test.ts'",
    "test:e2e:packaged": "node --no-warnings --experimental-strip-types --test-reporter=spec --test 'tests/*.packaged.test.ts'",
    "dist": "node ../../scripts/desktop-dist.mjs",
    "dist:ci": "node ../../scripts/desktop-dist.mjs --mac zip --x64 --arm64 --publish never",
    "dist:ci:mac": "node ../../scripts/desktop-dist.mjs --mac zip dmg --x64 --arm64 --publish never",
    "dist:ci:linux": "node ../../scripts/desktop-dist.mjs --linux AppImage deb --x64 --publish never"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opencode-ai/sdk": "^1.4.2",
    "@tanstack/react-virtual": "^3.13.24",
    "ajv": "^8.18.0",
    "dompurify": "^3.4.0",
    "google-auth-library": "^10.6.2",
    "marked": "^18.0.0",
    "mermaid": "^11.14.0",
    "morphdom": "^2.7.8",
    "opencode-ai": "1.4.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remend": "^1.3.0",
    "vega": "^6.2.0",
    "vega-embed": "^7.1.0",
    "vega-lite": "^6.4.2",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@open-cowork/shared": "workspace:*",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0",
    "playwright-core": "^1.59.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^6.0.3",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.0"
  }
}
