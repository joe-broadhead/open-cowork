{
  "name": "@open-cowork/desktop",
  "productName": "Open Cowork",
  "version": "0.0.0",
  "private": true,
  "description": "Desktop workspace for OpenCode sessions, agents, tools, skills, and workflows",
  "author": "Joe Broadhead",
  "license": "MIT",
  "homepage": "https://github.com/joe-broadhead/open-cowork",
  "repository": {
    "type": "git",
    "url": "https://github.com/joe-broadhead/open-cowork.git"
  },
  "main": "dist/main/index.js",
  "scripts": {
    "tokens:build": "pnpm --dir ../.. design-tokens:build",
    "ui:build": "pnpm --filter @open-cowork/ui build",
    "deps:build": "pnpm tokens:build && pnpm ui:build",
    "predev": "pnpm deps:build",
    "dev": "vite",
    "prebuild": "pnpm deps:build",
    "build": "vite build",
    "pretypecheck": "pnpm deps:build",
    "build:electron": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.preload.json --noEmit",
    "typecheck": "tsc --noEmit",
    "start": "electron .",
    "test:e2e": "pnpm --dir ../.. build:shared && pnpm --dir ../.. --filter @open-cowork/runtime-host build && pnpm build && pnpm build:electron && node ../../scripts/run-desktop-smoke-tests.mjs --pattern \"tests/*.smoke.test.ts\" --timeout=120000 --retries=1",
    "test:e2e:packaged": "node ../../scripts/require-packaged-executable.mjs && node ../../scripts/run-desktop-smoke-tests.mjs --pattern \"tests/*.packaged.test.ts\" --timeout=240000 --retries=1",
    "test:e2e:packaged:optional": "node ../../scripts/run-desktop-smoke-tests.mjs --pattern \"tests/*.packaged.test.ts\" --timeout=240000 --retries=1",
    "test:e2e:evals": "pnpm --dir ../.. build:shared && pnpm --dir ../.. --filter @open-cowork/runtime-host build && pnpm build && pnpm build:electron && node ../../scripts/run-desktop-smoke-tests.mjs --pattern \"tests/*.eval.test.ts\" --timeout=180000 --retries=1",
    "screenshots": "pnpm --dir ../.. build:shared && pnpm build && pnpm build:electron && node --no-warnings --experimental-strip-types tests/screenshots.ts",
    "dist": "node ../../scripts/desktop-dist.mjs",
    "dist:ci": "node ../../scripts/desktop-dist.mjs --mac zip --x64 --arm64 --publish never",
    "dist:ci:mac": "node ../../scripts/desktop-dist.mjs --mac zip dmg --x64 --arm64 --publish never",
    "dist:ci:linux": "node ../../scripts/desktop-dist.mjs --linux AppImage deb --x64 --publish never",
    "dist:ci:win": "node ../../scripts/desktop-dist.mjs --win nsis --x64 --publish never",
    "security": "pnpm audit --prod --audit-level high"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opencode-ai/sdk": "1.15.5",
    "electron-updater": "^6.8.9",
    "google-auth-library": "^10.9.0",
    "opencode-ai": "1.15.5",
    "semver": "^7.8.5",
    "vega": "^6.2.0",
    "vega-lite": "^6.4.3"
  },
  "devDependencies": {
    "@open-cowork/app": "workspace:*",
    "@open-cowork/cloud-server": "workspace:*",
    "@open-cowork/runtime-host": "workspace:*",
    "@open-cowork/shared": "workspace:*",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^22.20.0",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.8.1",
    "playwright-core": "^1.61.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vite-plugin-electron": "^1.1.0"
  }
}
