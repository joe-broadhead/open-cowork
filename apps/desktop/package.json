{
  "name": "@open-cowork/desktop",
  "productName": "Open Cowork",
  "version": "0.1.0",
  "private": true,
  "description": "Open Cowork desktop app powered by OpenCode",
  "author": "Joe Broadhead",
  "license": "MIT",
  "homepage": "https://github.com/joe-broadhead/opencowork",
  "repository": {
    "type": "git",
    "url": "https://github.com/joe-broadhead/opencowork.git"
  },
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:electron": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.preload.json --noEmit",
    "typecheck": "tsc --noEmit",
    "start": "electron .",
    "dist": "electron-builder",
    "dist:ci": "electron-builder --mac zip --x64 --arm64 --publish never"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.4.2",
    "better-sqlite3": "^11.0.0",
    "dompurify": "^3.3.3",
    "google-auth-library": "^9.0.0",
    "marked": "^18.0.0",
    "morphdom": "^2.7.8",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^9.0.0",
    "rehype-highlight": "^7.0.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remend": "^1.3.0",
    "vega": "^6.2.0",
    "vega-embed": "^7.1.0",
    "vega-lite": "^6.4.2",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@open-cowork/shared": "workspace:*",
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.19.17",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.8.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.0"
  }
}
