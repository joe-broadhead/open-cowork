{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    "types": ["node"],
    "paths": {
      "@open-cowork/cloud-client": ["../../packages/cloud-client/dist/index.d.ts"],
      "@open-cowork/cloud-client/*": ["../../packages/cloud-client/dist/*"],
      "@open-cowork/gateway-channel": ["../../packages/gateway-channel/dist/index.d.ts"],
      "@open-cowork/gateway-channel/*": ["../../packages/gateway-channel/dist/*"],
      "@open-cowork/gateway-provider-telegram": ["../../packages/gateway-provider-telegram/dist/index.d.ts"],
      "@open-cowork/gateway-provider-telegram/*": ["../../packages/gateway-provider-telegram/dist/*"],
      "@open-cowork/gateway-provider-webhook": ["../../packages/gateway-provider-webhook/dist/index.d.ts"],
      "@open-cowork/gateway-provider-webhook/*": ["../../packages/gateway-provider-webhook/dist/*"],
      "@open-cowork/gateway-testing": ["../../packages/gateway-testing/dist/index.d.ts"],
      "@open-cowork/gateway-testing/*": ["../../packages/gateway-testing/dist/*"],
      "@open-cowork/shared": ["../../packages/shared/dist/index.d.ts"],
      "@open-cowork/shared/*": ["../../packages/shared/dist/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.test.ts"]
}
