audit-level=moderate
engine-strict=true
strict-peer-dependencies=true

# The cloud server bundle (apps/desktop/dist/cloud/open-cowork-cloud.mjs, built by
# scripts/build-cloud.mjs with packages:'external') keeps these runtime deps as bare
# imports. Node resolves them by walking node_modules up from dist/cloud, which under
# pnpm's default isolated layout never reaches the .pnpm store where they live — so the
# bundle crashed at import with ERR_MODULE_NOT_FOUND 'ajv'. Public-hoist them to the
# workspace-root node_modules so the bundle (and its `pg` createRequire) resolve them.
public-hoist-pattern[]=ajv
public-hoist-pattern[]=pg
public-hoist-pattern[]=@aws-sdk/client-s3
public-hoist-pattern[]=@opencode-ai/sdk
