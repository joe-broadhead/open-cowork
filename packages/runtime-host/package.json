{
  "name": "@open-cowork/runtime-host",
  "version": "0.0.0",
  "private": true,
  "description": "Node + OpenCode-SDK runtime substrate shared by the desktop main process and the cloud server",
  "author": "Joe Broadhead",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/joe-broadhead/open-cowork.git",
    "directory": "packages/runtime-host"
  },
  "type": "module",
  "main": "dist/index.js",
