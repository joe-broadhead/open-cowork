{
  "name": "@open-cowork/app",
  "version": "0.0.0",
  "private": true,
  "description": "Unified Open Cowork renderer shared by the Electron desktop build and the cloud browser build",
  "author": "Joe Broadhead",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/joe-broadhead/open-cowork.git",
    "directory": "packages/app"
  },
  "type": "module",
  "scripts": {
    "build:browser": "vite build --config vite.config.browser.ts",
    "test:renderer": "vitest run --config vitest.renderer.config.ts",
    "test:coverage:renderer": "vitest run --config vitest.renderer.config.ts --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/mona-sans": "^5.2.8",
    "@fontsource-variable/schibsted-grotesk": "^5.2.8",
    "@open-cowork/shared": "workspace:*",
    "@open-cowork/ui": "workspace:*",
    "@tanstack/react-virtual": "^3.14.5",
    "dompurify": "^3.4.6",
    "lucide-react": "^1.23.0",
    "marked": "^18.0.5",
    "mermaid": "^11.16.0",
    "morphdom": "^2.7.8",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "remend": "^1.3.0",
    "vega": "^6.2.0",
    "vega-embed": "^7.1.0",
    "vega-lite": "^6.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "4.1.5",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.5",
    "vitest-axe": "^0.1.0"
  }
}
