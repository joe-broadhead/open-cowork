{
  "name": "@open-cowork/shared",
  "version": "0.0.0",
  "private": true,
  "description": "Shared Open Cowork product and wire types",
  "author": "Joe Broadhead",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/joe-broadhead/open-cowork.git",
    "directory": "packages/shared"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node/index.d.ts",
      "import": "./dist/node/index.js"
    },
    "./package.json": "./package.json",
    "./ipc-security-errors": {
      "types": "./dist/ipc-security-errors.d.ts",
      "import": "./dist/ipc-security-errors.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc && node ../../scripts/check-shared-dist.mjs",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "typescript": "^6.0.3"
  }
}
