{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": [
    "coverage/**",
    "dist/**",
    "site/**",
    "apps/desktop/dist/**",
    "apps/desktop/out/**",
    "apps/desktop/release/**",
    "THIRD_PARTY_LICENSES/**"
  ],
  "ignoreDependencies": [
    "opencode-ai"
  ],
  "workspaces": {
    ".": {
      "entry": [
        "eslint.config.mjs",
        "eslint.a11y.config.mjs",
        "scripts/*.mjs",
        "scripts/**/*.ts",
        ".github/scripts/*.mjs"
      ],
      "project": [
        "scripts/**/*.{js,mjs,ts}",
        ".github/scripts/*.mjs",
        "*.config.{js,mjs,ts}"
      ]
    },
    "apps/desktop": {
      "entry": [
        "src/main/index.ts",
        "src/preload/index.ts",
        "src/renderer/index.tsx",
        "src/renderer/chart-frame.ts",
        "tests/*.smoke.test.ts",
        "tests/*.packaged.test.ts",
        "tests/screenshots.ts"
      ],
      "project": [
        "src/**/*.{ts,tsx}",
        "tests/**/*.{ts,tsx}"
      ],
      "ignoreBinaries": [
        "electron"
      ],
      "ignoreDependencies": [
        "opencode-ai",
        "@fontsource-variable/mona-sans",
        "@fontsource-variable/schibsted-grotesk"
      ]
    },
    "apps/website": {
      "entry": [
        "src/render.ts",
        "src/react-client.tsx",
        "src/*.test.ts"
      ],
      "project": [
        "src/**/*.{ts,tsx}"
      ]
    },
    "apps/gateway": {
      "entry": [
        "src/index.ts",
        "src/*.test.ts"
      ],
      "project": [
        "src/**/*.ts"
      ]
    },
    "apps/standalone-gateway": {
      "entry": [
        "src/index.ts",
        "src/main.ts",
        "src/*.test.ts"
      ],
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/shared": {
      "entry": [
        "src/index.ts"
      ],
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/runtime-host": {
      "entry": [
        "src/index.ts",
        "src/config.ts",
        "src/runtime-managed-server-supervisor.ts"
      ],
      "project": [
        "src/**/*.ts"
      ],
      "ignoreBinaries": [
        "ps",
        "lsof",
        "taskkill"
      ],
      "ignoreDependencies": [
        "electron"
      ]
    },
    "packages/ui": {
      "entry": [
        "src/index.ts"
      ],
      "project": [
        "src/**/*.{ts,tsx}"
      ]
    },
    "packages/cloud-client": {
      "entry": [
        "src/index.ts",
        "test/public-import-smoke.mjs"
      ],
      "project": [
        "src/**/*.ts",
        "test/**/*.mjs"
      ]
    },
    "packages/cloud-server": {
      "entry": [
        "src/index.ts",
        "src/app.ts"
      ],
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/gateway-channel": {
      "entry": [
        "src/index.ts",
        "src/*.test.ts"
      ],
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/gateway-provider-cli": {
