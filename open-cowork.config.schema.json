{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Open Cowork Config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "allowedEnvPlaceholders": {
      "type": "array",
      "items": { "type": "string" }
    },
    "branding": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "appId": { "type": "string" },
        "dataDirName": { "type": "string" },
        "helpUrl": { "type": "string" },
        "projectNamespace": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "defaultTheme": { "type": "string" },
        "themes": {
          "type": "array",
          "items": { "$ref": "#/$defs/brandThemeDefinition" }
        },
        "sidebar": { "$ref": "#/$defs/brandingSidebar" },
        "home": { "$ref": "#/$defs/brandingHome" }
      },
      "required": ["name", "appId", "dataDirName", "helpUrl"]
    },
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["none", "google-oauth"]
        },
        "googleOAuth": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "clientId": { "type": "string" },
            "clientSecret": { "type": "string" },
            "scopes": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "required": ["clientId"]
        }
      },
      "required": ["mode"]
    },
    "providers": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "available": {
          "type": "array",
          "items": { "type": "string" }
        },
        "descriptors": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/providerDescriptorConfig"
          }
        },
        "defaultProvider": {
          "type": ["string", "null"]
        },
        "defaultModel": {
          "type": ["string", "null"]
        },
        "modelInfo": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/modelInfo"
          }
        },
        "custom": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "npm": { "type": "string" },
              "name": { "type": "string" },
              "description": { "type": "string" },
              "defaultModel": { "type": "string" },
              "smallModel": { "type": "string" },
              "options": {
                "type": "object",
                "additionalProperties": true
              },
              "models": {
                "type": "object",
                "additionalProperties": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "name": { "type": "string" },
                    "limit": { "$ref": "#/$defs/modelLimit" },
                    "cost": { "$ref": "#/$defs/modelCost" },
                    "options": {
                      "type": "object",
                      "additionalProperties": true,
                      "properties": {
                        "maxOutputTokens": { "type": "integer", "minimum": 1 }
                      }
                    }
                  }
                }
              },
              "credentials": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/credentialField"
                }
              }
            },
            "required": ["npm", "name", "models"]
          }
        }
      },
      "required": ["available", "defaultProvider", "defaultModel"]
    },
    "updates": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "manualFallbackUrl": { "$ref": "#/$defs/httpsOrLocalhostUrl" },
        "releaseSource": { "$ref": "#/$defs/updateReleaseSource" }
      }
    },
    "tools": {
      "type": "array",
      "items": { "$ref": "#/$defs/configuredTool" }
    },
    "skills": {
      "type": "array",
      "items": { "$ref": "#/$defs/configuredSkill" }
    },
    "mcps": {
      "type": "array",
      "items": { "$ref": "#/$defs/configuredMcp" }
    },
    "agents": {
      "type": "array",
      "items": { "$ref": "#/$defs/configuredAgent" }
    },
    "agentStarterTemplates": {
      "type": "array",
      "items": { "$ref": "#/$defs/agentStarterTemplate" }
    },
    "toolTrace": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rules": {
          "type": "array",
          "items": { "$ref": "#/$defs/toolTraceRule" }
        },
        "additionalRules": {
          "type": "array",
          "items": { "$ref": "#/$defs/toolTraceRule" }
        }
      }
    },
    "builtInAgents": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "build": { "$ref": "#/$defs/builtInAgentOverride" },
        "plan": { "$ref": "#/$defs/builtInAgentOverride" },
        "general": { "$ref": "#/$defs/builtInAgentOverride" },
        "explore": { "$ref": "#/$defs/builtInAgentOverride" }
      }
    },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bash": { "type": "string", "enum": ["allow", "ask", "deny"] },
        "fileWrite": { "type": "string", "enum": ["allow", "ask", "deny"] },
        "task": { "type": "string", "enum": ["allow", "ask", "deny"] },
        "web": { "type": "string", "enum": ["allow", "ask", "deny"] },
        "webSearch": {
          "type": "boolean",
          "description": "Enable OpenCode's native Exa-backed websearch integration by setting OPENCODE_ENABLE_EXA for the managed runtime."
        }
      },
      "required": ["bash", "fileWrite", "task", "web"]
    },
    "compaction": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "auto": { "type": "boolean" },
        "prune": { "type": "boolean" },
        "reserved": { "type": "integer", "minimum": 0 },
        "agent": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "model": { "type": "string" },
            "prompt": { "type": "string" },
            "temperature": { "type": "number" }
          }
        }
      }
    },
    "cloud": { "$ref": "#/$defs/cloudConfig" },
    "i18n": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "locale": {
          "type": "string",
          "maxLength": 64
        },
        "strings": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "maxLength": 4000
          }
        }
      }
    },
    "telemetry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "endpoint": {
          "type": "string",
          "maxLength": 2048,
          "pattern": "^https://.+"
        },
        "headers": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "maxLength": 4096
          }
        }
      }
    }
  },
  "required": ["allowedEnvPlaceholders", "branding", "auth", "providers", "tools", "skills", "mcps", "agents", "permissions"],
  "$defs": {
    "httpsOrLocalhostUrl": {
      "type": "string",
      "maxLength": 2048,
      "pattern": "^(https://|http://(127\\.0\\.0\\.1|localhost)(:[0-9]+)?/).+"
    },
    "cloudConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "role": { "$ref": "#/$defs/cloudRole" },
        "defaultProfile": { "$ref": "#/$defs/cloudName" },
        "profiles": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/cloudProfile" }
        },
        "auth": { "$ref": "#/$defs/cloudAuth" },
        "storage": { "$ref": "#/$defs/cloudStorage" },
        "runtime": { "$ref": "#/$defs/cloudRuntimePolicy" },
        "features": { "$ref": "#/$defs/cloudFeatures" }
      }
    },
    "cloudRole": {
      "type": "string",
      "enum": ["all-in-one", "web", "worker", "scheduler"]
    },
    "cloudName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$"
    },
    "cloudStringList": {
      "type": "array",
      "items": { "type": "string", "minLength": 1, "maxLength": 512 }
    },
    "cloudFeatures": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "chat": { "type": "boolean" },
        "agents": { "type": "boolean" },
        "artifacts": { "type": "boolean" },
        "threadIndex": { "type": "boolean" },
        "workflows": { "type": "boolean" },
        "webhooks": { "type": "boolean" },
        "settings": { "type": "boolean" },
        "customSkills": { "type": "boolean" },
        "customAgents": { "type": "boolean" },
        "customMcps": { "type": "boolean" }
      }
    },
    "cloudRuntimePolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "configSource": { "type": "string", "enum": ["app"] },
        "launcher": { "type": "string", "enum": ["node"] },
        "allowMachineRuntimeConfig": { "type": "boolean" },
        "allowLocalStdioMcps": { "type": "boolean" },
        "allowHostProjectDirectories": { "type": "boolean" },
        "allowedLocalMcpNames": { "$ref": "#/$defs/cloudStringList" },
        "allowedHostProjectDirectories": { "$ref": "#/$defs/cloudStringList" }
      }
    },
    "cloudProfile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "label": { "type": "string", "maxLength": 80 },
        "description": { "type": "string", "maxLength": 400 },
        "agents": { "$ref": "#/$defs/cloudStringList" },
        "tools": { "$ref": "#/$defs/cloudStringList" },
        "mcps": { "$ref": "#/$defs/cloudStringList" },
        "features": { "$ref": "#/$defs/cloudFeatures" },
        "runtime": { "$ref": "#/$defs/cloudRuntimePolicy" }
      }
    },
    "cloudAuth": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": { "type": "string", "enum": ["none", "oidc"] },
        "issuerUrl": { "type": "string", "pattern": "^https://.+" },
        "clientId": { "type": "string", "maxLength": 512 },
        "clientSecretRef": { "type": "string", "maxLength": 512 },
        "callbackPath": { "type": "string", "pattern": "^/[A-Za-z0-9/_-]*$" },
        "cookieSecretRef": { "type": "string", "maxLength": 512 },
        "allowedEmailDomains": { "$ref": "#/$defs/cloudStringList" }
      }
    },
    "cloudStorage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "controlPlane": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "kind": { "type": "string", "enum": ["local", "postgres"] },
            "urlRef": { "type": "string", "maxLength": 512 }
          }
        },
        "objectStore": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "kind": {
              "type": "string",
              "enum": ["filesystem", "s3", "gcs", "azure-blob", "digitalocean-spaces", "minio"]
            },
            "bucket": { "type": "string", "maxLength": 512 },
            "region": { "type": "string", "maxLength": 128 },
            "endpoint": { "type": "string", "maxLength": 2048 },
            "prefix": { "type": "string", "maxLength": 512 },
            "credentialsRef": { "type": "string", "maxLength": 512 }
          }
        }
      }
    },
    "updateChannel": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "pattern": "^[A-Za-z0-9._-]+$"
    },
    "updateReleaseSource": {
      "oneOf": [
        { "$ref": "#/$defs/githubUpdateReleaseSource" },
        { "$ref": "#/$defs/genericHttpUpdateReleaseSource" },
        { "$ref": "#/$defs/gcsUpdateReleaseSource" }
      ]
    },
    "githubUpdateReleaseSource": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "github-releases" },
        "label": { "type": "string", "minLength": 1, "maxLength": 80 },
        "owner": {
          "type": "string",
          "minLength": 1,
          "maxLength": 39,
          "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$"
        },
        "repo": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "pattern": "^[A-Za-z0-9._-]+$"
        },
        "channel": { "$ref": "#/$defs/updateChannel" },
        "auth": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "kind": { "type": "string", "enum": ["none", "github-token"] },
            "token": { "type": "string", "maxLength": 4096 }
          },
          "required": ["kind"]
        }
      },
      "required": ["kind"]
    },
    "genericHttpUpdateReleaseSource": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "generic-http" },
        "label": { "type": "string", "minLength": 1, "maxLength": 80 },
        "url": { "$ref": "#/$defs/httpsOrLocalhostUrl" },
        "channel": { "$ref": "#/$defs/updateChannel" },
        "auth": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "kind": { "type": "string", "enum": ["none", "static-headers"] },
            "headers": {
              "type": "object",
              "additionalProperties": {
                "type": "string",
                "maxLength": 4096
              }
            }
          },
          "required": ["kind"]
        }
      },
      "required": ["kind", "url"]
    },
    "gcsUpdateReleaseSource": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "gcs" },
        "label": { "type": "string", "minLength": 1, "maxLength": 80 },
        "bucket": {
          "type": "string",
          "minLength": 3,
          "maxLength": 222,
          "pattern": "^(?!.*\\.\\.)(?!\\d{1,3}(?:\\.\\d{1,3}){3}$)[a-z0-9][a-z0-9._-]*[a-z0-9]$"
        },
        "prefix": {
          "type": "string",
          "maxLength": 512,
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).*$"
        },
        "channel": { "$ref": "#/$defs/updateChannel" },
        "auth": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "kind": { "const": "google-oauth" },
                "requiredScopes": {
                  "type": "array",
                  "items": { "type": "string", "minLength": 1, "maxLength": 256 }
                }
              },
              "required": ["kind"]
            },
            {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "kind": { "const": "signed-url-broker" },
                "brokerUrl": { "$ref": "#/$defs/httpsOrLocalhostUrl" },
                "requiredScopes": {
                  "type": "array",
                  "items": { "type": "string", "minLength": 1, "maxLength": 256 }
                }
              },
              "required": ["kind", "brokerUrl"]
            }
          ]
        }
      },
      "required": ["kind", "bucket"]
    },
    "brandingSidebar": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "top": { "$ref": "#/$defs/brandingSidebarTop" },
        "lower": { "$ref": "#/$defs/brandingSidebarLower" }
      }
    },
    "brandingSidebarTop": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "variant": { "type": "string", "enum": ["icon", "text", "icon-text", "logo", "logo-text"] },
        "icon": { "type": "string", "maxLength": 16 },
        "logoAsset": {
          "type": "string",
          "maxLength": 512,
          "pattern": "^(?![A-Za-z][A-Za-z0-9+.-]*:)(?![\\\\/])(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).+\\.(svg|png|jpg|jpeg|webp|gif)$"
        },
        "logoDataUrl": {
          "type": "string",
          "maxLength": 65536,
          "pattern": "^data:image/(png|jpeg|jpg|webp|gif);base64,[A-Za-z0-9+/=]+$"
        },
        "mediaSize": {
          "type": "integer",
          "minimum": 16,
          "maximum": 96
        },
        "mediaFit": { "type": "string", "enum": ["vertical", "horizontal"] },
        "mediaAlign": { "type": "string", "enum": ["start", "center", "end"] },
        "title": { "type": "string", "maxLength": 48 },
        "subtitle": { "type": "string", "maxLength": 96 },
        "ariaLabel": { "type": "string", "maxLength": 96 }
      }
    },
    "brandingSidebarLower": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "text": { "type": "string", "maxLength": 120 },
        "secondaryText": { "type": "string", "maxLength": 160 },
        "linkLabel": { "type": "string", "maxLength": 64 },
        "linkUrl": {
          "type": "string",
          "maxLength": 2048,
          "pattern": "^(https://|mailto:).+"
        }
      }
    },
    "brandingHome": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "greeting": { "type": "string", "maxLength": 120 },
        "subtitle": { "type": "string", "maxLength": 180 },
        "composerPlaceholder": { "type": "string", "maxLength": 120 },
        "suggestionLabel": { "type": "string", "maxLength": 48 },
        "statusReadyLabel": { "type": "string", "maxLength": 48 }
      }
    },
    "credentialField": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "key": { "type": "string" },
        "runtimeKey": { "type": "string" },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "placeholder": { "type": "string" },
        "secret": { "type": "boolean" },
        "required": { "type": "boolean" },
        "env": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "select", "radio"] },
        "options": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "label": { "type": "string" },
              "value": { "type": "string" },
              "hint": { "type": "string" }
            },
            "required": ["label", "value"]
          }
        },
        "when": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "key": { "type": "string" },
            "op": { "type": "string", "enum": ["eq", "neq"] },
            "value": { "type": "string" }
          },
          "required": ["key", "op", "value"]
        }
      },
      "required": ["key", "label", "description"],
      "allOf": [
        {
          "if": {
            "required": ["type"],
            "properties": {
              "type": { "enum": ["select", "radio"] }
            }
          },
          "then": {
            "properties": {
              "options": {}
            },
            "required": ["options"]
          }
        }
      ]
    },
    "providerModelDescriptor": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "limit": { "$ref": "#/$defs/modelLimit" },
        "cost": { "$ref": "#/$defs/modelCost" },
        "featured": { "type": "boolean" },
        "contextLength": { "type": "number" }
      },
      "required": ["id", "name"]
    },
    "modelInfo": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "limit": { "$ref": "#/$defs/modelLimit" },
        "cost": { "$ref": "#/$defs/modelCost" }
      }
    },
    "modelLimit": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "context": { "type": "integer", "minimum": 1 },
        "output": { "type": "integer", "minimum": 1 }
      }
    },
    "modelCost": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "input": { "type": "number", "minimum": 0 },
        "output": { "type": "number", "minimum": 0 },
        "cache_read": { "type": "number", "minimum": 0 },
        "cache_write": { "type": "number", "minimum": 0 }
      }
    },
    "providerDescriptorConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "runtime": {
          "type": "string",
          "enum": ["builtin", "custom"]
        },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "defaultModel": { "type": "string" },
        "smallModel": { "type": "string" },
        "options": {
          "type": "object",
          "additionalProperties": true
        },
        "credentials": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/credentialField"
          }
        },
        "models": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/providerModelDescriptor"
          }
        },
        "dynamicCatalog": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "url": { "type": "string", "pattern": "^https://.+" },
            "responsePath": { "type": "string" },
            "idField": { "type": "string" },
            "nameField": { "type": "string" },
            "descriptionField": { "type": "string" },
            "contextLengthField": { "type": "string" },
            "authHeader": { "type": "string" },
            "sha256": { "type": "string", "pattern": "^[A-Fa-f0-9]{64}$" },
            "cacheTtlMinutes": { "type": "number" }
          },
          "required": ["url"]
        }
      },
      "required": ["name", "description", "credentials", "models"]
    },
    "configuredTool": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "icon": { "type": "string" },
        "description": { "type": "string" },
        "kind": { "type": "string", "enum": ["mcp", "built-in"] },
        "namespace": { "type": "string" },
        "patterns": {
          "type": "array",
          "items": { "type": "string" }
        },
        "writeAccess": { "type": "boolean" },
        "defaultAccess": {
          "type": "boolean",
          "description": "Allow this read-only tool for every app-managed agent by default."
        },
        "allowPatterns": {
          "type": "array",
          "items": { "type": "string" }
        },
        "askPatterns": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["id", "name", "description", "kind"]
    },
    "configuredSkill": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "badge": { "type": "string", "enum": ["Skill"] },
        "sourceName": { "type": "string" },
        "toolIds": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["name", "description", "badge", "sourceName"]
    },
    "configuredMcp": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["local", "remote"] },
        "description": { "type": "string" },
        "authMode": { "type": "string", "enum": ["none", "oauth", "api_token"] },
        "packageName": { "type": "string" },
        "command": {
          "type": "array",
          "items": { "type": "string" }
        },
        "url": { "type": "string" },
        "headers": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "headerSettings": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "header": { "type": "string" },
              "key": { "type": "string" },
              "prefix": { "type": "string" }
            },
            "required": ["header", "key"]
          }
        },
        "envSettings": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "env": { "type": "string" },
              "key": { "type": "string" }
            },
            "required": ["env", "key"]
          }
        },
        "credentials": {
          "type": "array",
          "items": { "$ref": "#/$defs/credentialField" }
        },
        "credentialHelp": { "type": "string" },
        "allowPrivateNetwork": { "type": "boolean" },
        "googleAuth": { "type": "boolean" }
      },
      "required": ["name", "type", "description", "authMode"]
    },
    "configuredAgent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "instructions": { "type": "string" },
        "skillNames": {
          "type": "array",
          "items": { "type": "string" }
        },
        "toolIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "allowTools": {
          "type": "array",
          "items": { "type": "string" }
        },
        "askTools": {
          "type": "array",
          "items": { "type": "string" }
        },
        "color": { "type": "string" },
        "hidden": { "type": "boolean" },
        "mode": { "type": "string", "enum": ["primary", "subagent"] },
        "model": { "type": "string" },
        "variant": { "type": "string" },
        "temperature": { "type": "number", "minimum": 0 },
        "top_p": { "type": "number", "minimum": 0, "maximum": 1 },
        "steps": { "type": "integer", "minimum": 1 },
        "options": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "required": ["name", "description", "instructions"]
    },
    "agentStarterTemplate": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "color": { "type": "string" },
        "instructions": { "type": "string" },
        "temperature": { "type": ["number", "null"], "minimum": 0 },
        "steps": { "type": ["integer", "null"], "minimum": 1 },
        "toolIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "skillNames": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["id", "label", "description", "color", "instructions"]
    },
    "toolTraceMatcher": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "exact": {
          "type": "array",
          "items": { "type": "string" }
        },
        "prefixes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "contains": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "toolTraceRule": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "pluralLabel": { "type": "string" },
        "match": {
          "type": "array",
          "items": { "$ref": "#/$defs/toolTraceMatcher" }
        }
      },
      "required": ["id", "label", "match"]
    },
    "brandThemeTokens": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "base": { "type": "string" },
        "surface": { "type": "string" },
        "surfaceHover": { "type": "string" },
        "surfaceActive": { "type": "string" },
        "elevated": { "type": "string" },
        "border": { "type": "string" },
        "borderSubtle": { "type": "string" },
        "text": { "type": "string" },
        "textSecondary": { "type": "string" },
        "textMuted": { "type": "string" },
        "accent": { "type": "string" },
        "accentHover": { "type": "string" },
        "green": { "type": "string" },
        "amber": { "type": "string" },
        "red": { "type": "string" },
        "info": { "type": "string" },
        "accentForeground": { "type": "string" },
        "shadowCard": { "type": "string" },
        "shadowElevated": { "type": "string" },
        "bgImage": { "type": "string" }
      },
      "required": [
        "base", "surface", "surfaceHover", "surfaceActive", "elevated",
        "border", "borderSubtle", "text", "textSecondary", "textMuted",
        "accent", "accentHover", "green", "amber", "red", "info",
        "accentForeground", "shadowCard", "shadowElevated", "bgImage"
      ]
    },
    "brandThemeDefinition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "swatches": {
          "type": "array",
          "items": { "type": "string" }
        },
        "dark": { "$ref": "#/$defs/brandThemeTokens" },
        "light": { "$ref": "#/$defs/brandThemeTokens" }
      },
      "required": ["id", "label", "dark"]
    },
    "builtInAgentOverride": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "disable": { "type": "boolean" },
        "hidden": { "type": "boolean" },
        "description": { "type": "string" },
        "instructions": { "type": "string" },
        "color": { "type": "string" },
        "model": { "type": "string" },
        "variant": { "type": "string" },
        "temperature": { "type": "number", "minimum": 0 },
        "top_p": { "type": "number", "minimum": 0, "maximum": 1 },
        "steps": { "type": "integer", "minimum": 1 },
        "options": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
