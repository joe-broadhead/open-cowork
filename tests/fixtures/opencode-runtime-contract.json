      "fixturePath": "tests/fixtures/opencode-sdk-v2-events.json",
      "events": [
        "assistant-text",
        "tool-completed",
        "permission-requested",
        "question-asked",
        "todos-updated",
        "status-idle",
        "step-cost",
        "runtime-error"
      ],
      "tests": ["tests/opencode-sdk-event-projection.test.ts", "tests/cloud-session-projection-contract.test.ts"]
    }
  ],
  "httpRoutes": [
    {
      "id": "opencode-session-create-route",
      "owner": "desktop-runtime",
      "method": "POST",
      "path": "/session",
      "tests": ["tests/cloud-opencode-runtime-adapter.test.ts"]
    },
    {
      "id": "opencode-session-prompt-route",
      "owner": "desktop-runtime",
      "method": "POST",
      "path": "/session/{sessionID}/prompt_async",
      "tests": ["tests/cloud-opencode-runtime-adapter.test.ts"]
    },
    {
      "id": "opencode-session-events-route",
      "owner": "desktop-runtime",
      "method": "GET",
      "path": "/event",
      "tests": ["tests/cloud-opencode-runtime-adapter.test.ts", "tests/opencode-sdk-event-projection.test.ts"]
    }
  ],
  "clientMethods": [
    {
      "id": "client-method-question-reply",
      "owner": "desktop-runtime",
      "method": "question.reply",
      "evidence": "Open Cowork preserves OpenCode-native question replies at execution while projecting user-facing state.",
      "tests": ["tests/question-normalization.test.ts", "tests/cloud-app.test.ts"]
    },
    {
      "id": "client-method-question-reject",
      "owner": "desktop-runtime",
      "method": "question.reject",
      "evidence": "Open Cowork forwards rejections through durable commands without replacing OpenCode question handling.",
      "tests": ["tests/question-normalization.test.ts", "tests/cloud-app.test.ts"]
    },
    {
      "id": "client-method-permission-respond",
      "owner": "desktop-runtime",
      "method": "permission.reply",
      "evidence": "Open Cowork gates remote approval responses but leaves permission execution semantics with OpenCode.",
      "tests": ["tests/permission-config.test.ts", "tests/cloud-app.test.ts"]
    }
