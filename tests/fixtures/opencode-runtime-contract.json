    "opencode-sdk-v2-import-boundary",
    "permission-question-roundtrip-contract",
    "runtime-config-builder-sdk-native-config"
  ],
  "runtimeConfig": [
    {
      "id": "runtime-config-provider-models",
      "owner": "desktop-runtime",
      "key": "provider",
      "evidence": "Open Cowork emits provider/model settings through the SDK-native runtime config builder.",
      "tests": ["tests/runtime-config-builder.test.ts"]
    },
    {
      "id": "runtime-config-agent-permissions",
      "owner": "desktop-runtime",
      "key": "agent.permission",
      "evidence": "Built-in and custom agents retain OpenCode-native permission config instead of app-side runtime mirroring.",
      "tests": ["tests/permission-config.test.ts", "tests/permission-inheritance.test.ts"]
    },
    {
      "id": "runtime-config-mcp-skills",
      "owner": "capabilities",
      "key": "mcp",
      "evidence": "Managed MCP and skill discovery is curated by Open Cowork and emitted into OpenCode config.",
      "tests": ["tests/runtime-config-builder.test.ts", "tests/capability-bundle-runtime-preflight.test.ts"]
    }
  ],
  "sdkEvents": [
    {
