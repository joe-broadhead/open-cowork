{
  "$schema": "../../../open-cowork.config.schema.json",
  "contractVersion": 1,
  "allowedEnvPlaceholders": [
    "OPEN_COWORK_GATEWAY_SERVICE_TOKEN",
    "OPEN_COWORK_GATEWAY_ADMIN_TOKEN",
    "OPEN_COWORK_GATEWAY_TELEGRAM_BOT_TOKEN",
    "OPEN_COWORK_GATEWAY_TELEGRAM_WEBHOOK_SECRET",
    "OPEN_COWORK_GATEWAY_SLACK_BOT_TOKEN",
    "OPEN_COWORK_GATEWAY_SLACK_SIGNING_SECRET",
    "OPEN_COWORK_GATEWAY_EMAIL_INBOUND_SECRET",
    "OPEN_COWORK_GATEWAY_EMAIL_SMTP_PASSWORD"
  ],
  "branding": {
    "name": "Example Cowork",
    "shortName": "EX",
    "appId": "com.example.cowork",
    "dataDirName": "example-cowork",
    "helpUrl": "https://support.example.com/cowork",
    "supportUrl": "https://support.example.com/cowork",
    "privacyUrl": "https://legal.example.com/privacy",
    "securityUrl": "https://security.example.com/cowork",
    "legalUrl": "https://legal.example.com/terms",
    "projectNamespace": "example-cowork",
    "sidebar": {
      "top": {
        "variant": "text",
        "title": "Example Cowork",
        "subtitle": "Internal agent workspace"
      },
      "lower": {
        "text": "Example internal",
        "linkLabel": "Support",
        "linkUrl": "https://support.example.com/cowork"
      }
    }
  },
  "auth": {
    "mode": "none"
  },
  "providers": {
    "available": [],
    "defaultProvider": null,
    "defaultModel": null
  },
  "tools": [],
  "skills": [],
  "mcps": [],
  "agents": [],
  "permissions": {
    "bash": "ask",
    "fileWrite": "ask",
    "task": "allow",
    "web": "allow",
    "webSearch": true
  },
  "cloud": {
    "role": "all-in-one",
    "defaultProfile": "data-analyst",
    "publicBranding": {
      "productName": "Example Cowork",
      "shortName": "EX",
      "logoUrl": "https://assets.example.com/cowork/logo.png",
      "supportUrl": "https://support.example.com/cowork",
      "privacyUrl": "https://legal.example.com/privacy",
      "securityUrl": "https://security.example.com/cowork",
      "legalUrl": "https://legal.example.com/terms",
      "theme": {
        "background": "#f7f8f5",
        "surface": "#ffffff",
        "mutedSurface": "#e8eee9",
        "border": "#cfd9d2",
        "text": "#142018",
        "mutedText": "#5f6f66",
        "accent": "#0f6b4b",
        "accentStrong": "#0a4c35"
      },
      "dashboard": {
        "title": "Example workspace",
        "subtitle": "Manage Example Cowork keys, clients, and channel agents.",
        "connectionsDescription": "Issue scoped Example Cowork tokens for approved desktop and gateway clients.",
        "gatewayDescription": "Connect approved chat channels to Example Cowork cloud sessions."
      },
      "managedOrgConnectionLabels": {
        "desktopToken": "Example Desktop token",
        "gatewayToken": "Example Gateway token",
        "apiToken": "Example API token",
        "cloudUrl": "Example Cloud URL"
      }
    },
    "auth": {
      "mode": "oidc",
      "issuerUrl": "https://idp.example.com",
      "clientId": "example-cowork-cloud",
      "callbackPath": "/auth/callback",
      "cookieSecretRef": "env:OPEN_COWORK_CLOUD_COOKIE_SECRET",
      "allowedEmailDomains": ["example.com"],
      "allowSelfServiceSignup": false
    },
    "storage": {
      "controlPlane": {
        "kind": "postgres",
        "urlRef": "env:OPEN_COWORK_CLOUD_DATABASE_URL"
      },
      "objectStore": {
        "kind": "s3",
        "bucket": "example-cowork-artifacts",
        "region": "us-east-1",
        "prefix": "production/",
        "credentialsRef": "env:OPEN_COWORK_CLOUD_OBJECT_STORE_CREDENTIALS"
      }
    },
    "features": {
      "chat": true,
      "agents": true,
      "artifacts": true,
      "threadIndex": true,
      "workflows": false,
      "webhooks": false,
      "settings": true,
      "customSkills": false,
      "customAgents": false,
      "customMcps": false
    },
    "profiles": {
      "data-analyst": {
        "label": "Data analyst",
        "description": "Focused example deployment exposing only the data analyst surface.",
        "agents": ["data-analyst"],
        "tools": ["explorer.read", "charts.save"],
        "mcps": [],
        "features": {
          "chat": true,
          "agents": true,
          "artifacts": true,
          "threadIndex": true,
          "workflows": false,
          "webhooks": false,
          "settings": true,
          "customSkills": false,
          "customAgents": false,
          "customMcps": false
        }
      }
    }
  },
  "cloudDesktop": {
    "enabled": true,
    "allowUserAddedConnections": false,
    "preconfiguredConnections": [
      {
        "baseUrl": "https://cowork.example.com",
        "label": "Example Cowork"
      }
    ],
    "requireManagedOrg": true,
    "cacheMode": "metadata-only",
    "cacheEncryptionFallback": "fail-startup"
  },
  "gateway": {
    "branding": {
      "productName": "Example Cowork",
      "shortName": "EX",
      "logoUrl": "https://assets.example.com/cowork/logo.png",
      "supportUrl": "https://support.example.com/cowork",
      "privacyUrl": "https://legal.example.com/privacy",
      "securityUrl": "https://security.example.com/cowork",
      "legalUrl": "https://legal.example.com/terms",
      "managedOrgConnectionLabels": {
        "desktopToken": "Example Desktop token",
        "gatewayToken": "Example Gateway token",
        "apiToken": "Example API token",
        "cloudUrl": "Example Cloud URL"
      }
    },
    "cloud": {
      "baseUrl": "https://cowork.example.com",
      "serviceToken": "{env:OPEN_COWORK_GATEWAY_SERVICE_TOKEN}",
      "allowInsecureHttp": false
    },
    "productMode": "cloud_channel",
    "server": {
      "host": "0.0.0.0",
      "port": 8790,
      "publicBaseUrl": "https://cowork-gateway.example.com",
      "adminToken": "{env:OPEN_COWORK_GATEWAY_ADMIN_TOKEN}"
    },
    "mode": "self-host",
    "logging": {
      "level": "info"
    },
    "metrics": {
      "enabled": false
    },
    "diagnostics": {
      "enabled": false
    },
    "providers": [
      {
        "id": "example-telegram",
        "kind": "telegram",
        "channelBindingId": "example-telegram",
        "credentials": {
          "botToken": "{env:OPEN_COWORK_GATEWAY_TELEGRAM_BOT_TOKEN}",
          "webhookSecret": "{env:OPEN_COWORK_GATEWAY_TELEGRAM_WEBHOOK_SECRET}"
        },
        "settings": {
          "mode": "webhook",
          "publicBaseUrl": "https://cowork-gateway.example.com"
        }
      },
      {
        "id": "example-slack",
        "kind": "slack",
        "channelBindingId": "example-slack",
        "externalWorkspaceId": "TEXAMPLE1",
        "credentials": {
          "botToken": "{env:OPEN_COWORK_GATEWAY_SLACK_BOT_TOKEN}",
          "signingSecret": "{env:OPEN_COWORK_GATEWAY_SLACK_SIGNING_SECRET}"
        },
        "settings": {
          "teamId": "TEXAMPLE1"
        }
      },
      {
        "id": "example-email",
        "kind": "email",
        "channelBindingId": "example-email",
        "externalWorkspaceId": "example.com",
        "credentials": {
          "inboundSecret": "{env:OPEN_COWORK_GATEWAY_EMAIL_INBOUND_SECRET}",
          "smtpPassword": "{env:OPEN_COWORK_GATEWAY_EMAIL_SMTP_PASSWORD}"
        },
        "settings": {
          "from": "agent@example.com",
          "inboundAddress": "agent@example.com",
          "smtpHost": "smtp.example.com",
          "smtpPort": "587",
          "smtpSecure": "false",
          "smtpUsername": "agent@example.com"
        }
      }
    ]
  }
}
